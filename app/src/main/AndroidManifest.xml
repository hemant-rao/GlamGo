<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for the VedaDrop REST/API integration (Retrofit/OkHttp). -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- §687 — device location for "use current location", near-me discovery
         sorting, and live job tracking. COARSE is sufficient if the user denies
         FINE; both are runtime-requested in MainActivity. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- §706 — partner KYC selfie + ID-document capture. TakePicturePreview
         returns a Bitmap thumbnail so no FileProvider is needed. Camera is
         optional so devices without one can still install. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <!-- §710 P0-5 — show FCM push notifications (booking accepted, chat, new job).
         POST_NOTIFICATIONS is runtime-requested on Android 13+. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- §774 — first-time phone verification by reading the user's OWN SIM number
         (proof the registered number's SIM is physically in this device, so we can
         auto-verify with no OTP). READ_PHONE_NUMBERS reads the SIM's number;
         READ_PHONE_STATE enumerates each active SIM (dual-SIM). Both are
         runtime-requested only on the sign-up phone step (SimNumberReader). This is
         the Play-approved "verify the user's own phone number" use-case; the flow
         degrades to the one-tap Phone Number Hint chooser if the permission is
         denied or the carrier doesn't expose the number. -->
    <uses-permission android:name="android.permission.READ_PHONE_NUMBERS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <!-- §725 Batch-B — urgent-job high-alert alarm. A foreground service loops an
         ALARM-stream sound + posts a full-screen-intent notification so a partner
         cannot miss a customer waiting right now. MEDIA_PLAYBACK is the FGS type
         required on targetSdk 34+. USE_FULL_SCREEN_INTENT lights the screen / shows
         the alert even when locked. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyApplication">
        <!-- §756 — Google AdMob app id. This is Google's PUBLIC SAMPLE app id (safe to
             ship; serves only test ads). The founder replaces it with the real AdMob
             App ID from the Veda Drop admin (Settings → Ads & Apps → Veda Drop → AdMob
             App ID) before the production build. Real ads only show once a real id is
             set AND the admin master switch is on. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713" />
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.MyApplication">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- §710 P0-5 — FCM push receiver (deep-links into the referenced item). -->
        <service
            android:name=".VedaDropMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- §725 Batch-B — urgent-job high-alert alarm foreground service. -->
        <service
            android:name=".UrgentAlarmService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
    </application>

</manifest>
